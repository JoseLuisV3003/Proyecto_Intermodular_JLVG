# Database configuration for Docker Compose
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=your_database_name_here
MYSQL_USER=your_db_user_here
MYSQL_PASSWORD=your_db_password_here

# Database URL for Prisma (use the same values as above)
DATABASE_URL="mysql://your_db_user_here:your_db_password_here@localhost:3306/your_database_name_here"

# Puerto de la app
PORT=3000

# Entorno
NODE_ENV=development